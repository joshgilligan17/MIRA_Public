# Copy to .env on the server. Do not commit real secrets.

# Use a real domain after DNS points to the Droplet, for example:
# MIRA_DOMAIN=mira.example.com
# For a temporary HTTP-only IP deployment, use:
MIRA_DOMAIN=:80

MIRA_DATA_DIR=/data/mira/jobs
MIRA_MAX_UPLOAD_MB=250
MIRA_BASIC_AUTH_USERNAME=mira
MIRA_BASIC_AUTH_PASSWORD=change-me

# MiniMax synthesis for the first deployment. Later we can swap this to Cloudflare Workers AI.
MIRA_REPORT_PROVIDER=minimax
MIRA_REPORT_MODEL=MiniMax-M2.7
MIRA_REPORT_BASE_URL=https://api.minimax.io/v1
MIRA_REPORT_API_KEY=

# Comma-separated origins only needed if you host the frontend separately from the API.
MIRA_CORS_ORIGINS=

# Keep defaults unless another service already uses these ports.
MIRA_HTTP_PORT=80
MIRA_HTTPS_PORT=443
