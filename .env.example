# Copy to .env on the server. Do not commit real secrets.

# Use a real domain after DNS points to the Droplet, for example:
# MIRA_DOMAIN=mira.example.com
# For a temporary HTTP-only IP deployment, use:
MIRA_DOMAIN=:80

MIRA_DATA_DIR=/data/mira/jobs
MIRA_PROJECT_DIR=/data/mira/projects
MIRA_MODEL_DIR=/data/mira/models
MIRA_MAX_UPLOAD_MB=250

# Optional private-deployment gate. Leave disabled for the public class demo.
# MIRA_BASIC_AUTH_ENABLED=true
# MIRA_BASIC_AUTH_USERNAME=mira
# MIRA_BASIC_AUTH_PASSWORD=change-me

# MiniMax synthesis for the first deployment. Later we can swap this to Cloudflare Workers AI.
MIRA_REPORT_PROVIDER=minimax
MIRA_REPORT_MODEL=MiniMax-M2.7
MIRA_REPORT_BASE_URL=https://api.minimax.io/v1
MIRA_REPORT_API_KEY=

# Local CPU design backends. Run scripts/install_foldingdiff_cpu.sh and/or
# scripts/install_proteinmpnn_cpu.sh on the server first.
MIRA_DEFAULT_DESIGN_LIBRARY=proteinmpnn
MIRA_FOLDINGDIFF_REPO=/data/mira/models/FoldingDiff
MIRA_FOLDINGDIFF_PYTHON=/data/mira/models/foldingdiff-venv/bin/python
MIRA_FOLDINGDIFF_DEVICE=cpu
MIRA_FOLDINGDIFF_MAX_DESIGNS=8
MIRA_FOLDINGDIFF_MAX_LENGTH=128
MIRA_FOLDINGDIFF_RUN_PSEA=false
MPLCONFIGDIR=/tmp/matplotlib
HF_HOME=/data/mira/models/huggingface
HUGGINGFACE_HUB_CACHE=/data/mira/models/huggingface/hub
TRANSFORMERS_CACHE=/data/mira/models/huggingface/transformers
MIRA_PROTEINMPNN_REPO=/data/mira/models/ProteinMPNN
MIRA_PROTEINMPNN_PYTHON=/data/mira/models/proteinmpnn-venv/bin/python

# Comma-separated origins only needed if you host the frontend separately from the API.
MIRA_CORS_ORIGINS=

# Keep defaults unless another service already uses these ports.
MIRA_HTTP_PORT=80
MIRA_HTTPS_PORT=443
